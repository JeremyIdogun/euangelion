# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spotify Web API (server-side only)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_MARKET=US
SPOTIFY_REDIRECT_URI=https://your-domain.com/api/spotify/auth/callback

# YouTube Data API (server-side only, for unlisted playlist ingestion)
YOUTUBE_API_KEY=your-youtube-data-api-key

# Admin auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret

# Cron protection
CRON_SECRET=your-random-cron-secret
